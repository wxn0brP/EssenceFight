{
	"compilerOptions": {
		"module": "es2022",
		"target": "es2024",
		"moduleResolution": "bundler",
		"paths": {
			"#*": [
				"./src/*"
			],
			"_*": [
				"../src/shared/*"
			]
		},
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"strict": false
	},
	"include": [
		"./src"
	],
	"exclude": [
		"node_modules"
	]
}
