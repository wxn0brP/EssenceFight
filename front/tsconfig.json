{
	"compilerOptions": {
		"module": "es2022",
		"target": "es2024",
		"moduleResolution": "bundler",
		"paths": {
			"#*": [
				"./src/*"
			],
			"_*": [
				"../src/shared/*"
			]
		},
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"declaration": true
	},
	"include": [
		"./src"
	],
	"exclude": [
		"node_modules"
	]
}